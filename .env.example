# === Database ===
POSTGRES_USER=poise
POSTGRES_PASSWORD=poise_dev
POSTGRES_DB=poise
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://poise:poise_dev@postgres:5432/poise

# === Redis / Celery ===
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=db+postgresql+psycopg://poise:poise_dev@postgres:5432/poise

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-prod-use-openssl-rand-hex-32
API_JWT_ALG=HS256
API_JWT_EXPIRE_MINUTES=720
API_CORS_ORIGINS=http://localhost:3000

# === LLM (DeepSeek default, OpenAI/Azure fallback) ===
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_CHAT=deepseek-chat
DEEPSEEK_MODEL_LITE=deepseek-chat
# Fallback
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_CHAT=gpt-4o
OPENAI_MODEL_LITE=gpt-4o-mini

# === Solver ===
# MVP 默认 cbc（稳定）；如启用 HiGHS 性能更优但当前 pulp 3.3+highspy 1.14 兼容性偶发问题。
SOLVER_BACKEND=cbc
SOLVER_TIME_LIMIT_SEC=30

# === Web (Next.js / NextAuth) ===
# 浏览器从宿主访问 API 用此 URL（API 在宿主 8001 端口）
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
# Next.js 服务端（Server Components / NextAuth authorize）在 docker 网络内调 API
INTERNAL_API_BASE_URL=http://api:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-prod-use-openssl-rand-hex-32
